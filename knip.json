{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "bin/jscad-work.js",
    "mcp/server.js",
    "mcp/lib/catalog.js",
    "test/**/*.test.js",
    "scripts/build-catalog.js"
  ],
  "project": ["bin/**/*.js", "mcp/**/*.js", "scripts/**/*.js"],
  "ignoreIssues": {
    "scripts/lib/describe.js": ["exports"],
    "scripts/lib/verify.js": ["exports"]
  },
  "ignoreDependencies": [
    "@jbroll/jscad-fluent",
    "@jscadui/params-core",
    "@jscadui/openscad",
    "@jscadui/openscad-runtime",
    "@jscadui/manifold",
    "@jscadui/jscad-text",
    "@biomejs/biome",
    "dpdm"
  ]
}
